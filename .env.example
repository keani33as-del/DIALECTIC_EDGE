# =============================================================================
# Dialectic Edge — .env.example
# =============================================================================
# Скопируй файл в .env и заполни значения. .env уже в .gitignore.
# Пустые ключи допустимы — без них отключаются соответствующие фичи
# (например, без TAVILY_API_KEY web-search падает на fallback).
#
# В Railway эти же переменные задаются через Settings → Variables.
# =============================================================================

# ─── Telegram ────────────────────────────────────────────────────────────────
# Токен от @BotFather. Без него бот не стартует.
BOT_TOKEN=123456:ABC-...
# Telegram user_id админов через запятую (для /audit, /stop, /starttrade и т.п.).
ADMIN_IDS=0

# ─── AI provider routing ─────────────────────────────────────────────────────
# Активный первичный провайдер (gemini | groq | mistral | openrouter | together | cerebras).
# Bull/Bear/Verifier/Synth разводятся по моделям через переменные ниже.
AI_PROVIDER=gemini

# Бесплатные / дешёвые LLM-провайдеры. Хватит даже одного, остальные — fallback.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GROQ_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=

# Локальные / совместимые с OpenAI endpoint'ы (Ollama / LM Studio).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OPENAI_COMPAT_BASE_URL=http://localhost:1234/v1
OPENAI_COMPAT_API_KEY=lm-studio
OPENAI_COMPAT_MODEL=local-model

# HuggingFace token для FinBERT sentiment (опционально, без него локальный inference).
HF_TOKEN=

# ─── Дебаты ──────────────────────────────────────────────────────────────────
DEBATE_ROUNDS=3
MAX_TOKENS=1500
AGENT_TEMP=0.7

# ─── Источники данных ────────────────────────────────────────────────────────
# Все ключи бесплатные на free tier'ах.
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
FRED_API_KEY=
TAVILY_API_KEY=
NEWS_API_KEY=

# Bybit (только если используются приватные эндпоинты — публичные сигналы работают без ключа).
BYBIT_API_KEY=
BYBIT_SECRET_KEY=

# ─── State persistence в git (для рестартов без потери истории) ──────────────
# Бот коммитит DIGEST_CACHE.md / AUTO_TRACK.md / FORECASTS.md обратно в репо.
GITHUB_TOKEN=
GITHUB_REPO=ANAEHY/dialectic_edge
GITHUB_DEFAULT_BRANCH=master
GITHUB_DATA_BRANCH=data/market-cache

# ─── Хранилище (SQLite + cache) ──────────────────────────────────────────────
# На Railway монтируется Volume — путь придёт из RAILWAY_VOLUME_MOUNT_PATH автоматически.
# Локально — оставь пусто, файлы лягут в корень репо.
DATA_DIR=
DB_PATH=dialectic_edge.db
CACHE_FILE=cache.json
CACHE_TTL_HOURS=24
DEBATE_SNAPSHOT_HOURS=72

# Redis для снимков дебатов (опционально, нужен только если >1 воркера или важна
# кнопка «листать» после рестарта). Без REDIS_URL — fallback на SQLite/JSON.
REDIS_URL=

# ─── Risk / autotrade фичефлаги (см. config.py для полного списка) ───────────
FEATURE_AUTOTRADE=1
AUTOTRADE_START_CAPITAL=500.0
AUTOTRADE_INTERVAL_SEC=60
AUTOTRADE_OPEN_SCORE_THRESHOLD=18
AUTOTRADE_REVERSAL_SCORE_THRESHOLD=16
AUTOTRADE_MIN_HOLD_MINUTES=15
AUTOTRADE_REENTRY_COOLDOWN_MIN=30
LOG_AUTOTRADE_SKIPS=0

# ─── Прочее ──────────────────────────────────────────────────────────────────
# Принудительно отключить SSL-проверку Росстата (на Railway случается, использовать осознанно):
RUSSIA_ROSSTAT_INSECURE_SSL=
# Принудительно отключить SSL-проверку CFTC (COT data):
COT_INSECURE_SSL=
# Сколько реплик у Railway worker'a (используется в guard'е main.py).
RAILWAY_REPLICA_COUNT=1
